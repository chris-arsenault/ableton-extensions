{
  "name": "ableton-extensions",
  "private": true,
  "version": "0.0.0",
  "description": "Ableton Live Extensions (Extensions SDK) — personal tools that bridge Live into the Sulion family of services.",
  "engines": {
    "node": ">=24.16.0"
  },
  "workspaces": [
    "shared",
    "packages/*"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "npm run build --workspaces --if-present",
    "lint": "echo \"(no linter configured yet)\" && exit 0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "esbuild": "^0.23.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
